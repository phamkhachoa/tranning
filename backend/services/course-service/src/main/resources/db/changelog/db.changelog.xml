                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <include file="db/changelog/changes/001-init.sql" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/002-rich-lesson-items.sql" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/003-item-progress.sql" relativeToChangelogFile="false"/>
    <include file="db/changelog/changes/004-optimistic-lock-columns.sql" relativeToChangelogFile="false"/>
