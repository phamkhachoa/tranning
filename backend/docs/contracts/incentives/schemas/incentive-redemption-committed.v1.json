{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://courseflow.local/contracts/incentives/schemas/incentive-redemption-committed.v1.json",
  "title": "IncentiveRedemptionCommittedEventV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "schemaVersion",
    "tenantId",
    "applicationId",
    "reservationId",
    "redemptionId",
    "campaignId",
    "campaignVersion",
    "profileId",
    "correlationId",
    "sourceClientId",
    "effects",
    "committedAt"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "schemaVersion": { "type": "integer", "const": 1 },
    "tenantId": { "type": "string", "minLength": 1 },
    "applicationId": { "type": "string", "minLength": 1 },
    "reservationId": { "type": "string", "format": "uuid" },
    "redemptionId": { "type": "string", "format": "uuid" },
    "campaignId": { "type": "string", "format": "uuid" },
    "campaignVersion": { "type": "integer", "minimum": 1 },
    "couponId": { "type": ["string", "null"], "format": "uuid" },
    "profileId": { "type": "string", "minLength": 1 },
    "externalReference": { "type": ["string", "null"] },
    "correlationId": {
      "type": ["string", "null"],
      "description": "Nullable when callers omit X-Correlation-Id; gateways should provide it."
    },
    "sourceClientId": {
      "type": ["string", "null"],
      "description": "Nullable when the internal JWT does not contain a client id claim."
    },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "incentive-effect.v1.json" }
    },
    "committedAt": { "type": "string", "format": "date-time" },
    "metadata": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  }
}
