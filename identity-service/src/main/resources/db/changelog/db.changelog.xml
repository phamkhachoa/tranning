<?xml version="1.0" encoding="UTF-8"?>
<!--
  Single master changelog for identity-service.
  Add a new migration by dropping a NNN-*.sql under db/changelog/changes/ and
  registering it here as a new <include>. Keep includes in numeric order.
-->
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <include file="db/changelog/changes/001-init.sql" relativeToChangelogFile="false"/>
</databaseChangeLog>
